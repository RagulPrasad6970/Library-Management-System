# Create .gitignore
@"
# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
env/
venv/
.venv
*.egg-info/
dist/
build/

# Django
*.log
db.sqlite3
.venv/
/media/
/staticfiles/

# Environment variables
.env
.env.local

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Frontend (if exists)
node_modules/
frontend/node_modules/
"@ | Out-File -Encoding UTF8 .gitignore